  "bin": {
    "plandeck": "bin/plandeck.ts"
  },
  "scripts": {
    "dev": "vite",
    "start": "bun src/server/index.ts",
    "build": "tsc --noEmit && vite build",
    "gen:embedded": "bun scripts/gen-embedded.ts",
    "build:binary": "bun run build && bun run gen:embedded && bun scripts/compile.ts && git checkout -- src/server/embedded-assets.ts",
    "check": "biome check . && tsc --noEmit",
    "test": "bun test",
    "e2e": "bash scripts/e2e.sh"
  },
  "dependencies": {
    "@mantine/core": "^7.17.0",
    "@mantine/hooks": "^7.17.0",
    "@mdx-js/mdx": "^3.1.1",
