    "@shikijs/rehype": "^4.2.0",
    "@tanstack/react-query": "^5.80.7",
    "@testing-library/user-event": "^14.6.1",
    "chokidar": "^5.0.0",
    "citty": "^0.2.2",
    "hono": "^4.7.10",
    "ignore": "^7.0.5",
    "lucide-react": "^1.21.0",
    "mdast-util-to-string": "^4.0.0",
    "mermaid": "^11.15.0",
    "open": "^11.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.30.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
