    "@testing-library/react": "^16.3.0",
    "@types/bun": "^1.2.15",
    "@types/node": "^26.0.0",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.5.2",
    "happy-dom": "^17.5.8",
    "postcss": "^8.5.5",
    "postcss-preset-mantine": "^1.17.0",
